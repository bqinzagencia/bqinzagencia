rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins collection — solo superadmins
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Solo via Firebase Console
    }

    // Superadmin: lectura y escritura total sobre empresas
    match /empresas/{empresaId} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Superadmin: lectura y escritura total sobre subcolecciones
    match /empresas/{empresaId}/{subcol}/{docId} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Empresas — cada empresa solo ve y edita sus propios datos
    match /empresas/{empresaId} {
      allow read, write: if request.auth != null && request.auth.uid == empresaId;
    }

    match /empresas/{empresaId}/agentes/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == empresaId;
    }
    match /empresas/{empresaId}/conversaciones/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == empresaId;
    }
    match /empresas/{empresaId}/conversaciones/{convId}/mensajes/{msgId} {
      allow read, write: if request.auth != null && request.auth.uid == empresaId;
    }
    match /empresas/{empresaId}/contactos/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == empresaId;
    }
    match /empresas/{empresaId}/citas/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == empresaId;
    }
    match /empresas/{empresaId}/config/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == empresaId;
    }
  }
}
