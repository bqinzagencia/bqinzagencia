rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Cada empresa solo puede subir/leer sus propios archivos
    match /webs/{userId}/{allPaths=**} {
      allow read: if true; // Fotos de web son públicas
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /logos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 4 * 1024 * 1024;
    }
  }
}
